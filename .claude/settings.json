{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/unrestricted-bash-guard.sh",
            "timeout": 30,
            "statusMessage": "Checking command against unrestricted-mode policy…"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/execute-events.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/lazy-stop-watcher.sh",
            "timeout": 30,
            "statusMessage": "Checking turn for lazy bail-out…"
          }
        ]
      }
    ]
  }
}
